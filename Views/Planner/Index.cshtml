                            <span data-i18n="migration-speed">Migration Speed (%)</span>
                            <input asp-for="AdvanceForm.MigrationSpeed" class="form-control" type="number" step="0.01" />
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="material-button ghost-button" data-bs-dismiss="modal" data-i18n="cancel">Cancel</button>
                    <button type="submit" class="material-button primary-button" data-i18n="save-content" data-submit-content-button data-add-label-key="save-content" data-edit-label-key="save-content-edit">Save content</button>
                </div>
            </form>
        </div>
    </div>
</div>
}

