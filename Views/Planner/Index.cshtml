                            <input asp-for="AdvanceForm.AssimilationConversionSpeed" class="form-control" type="number" min="0" max="100" step="0.01" />
                        </label>
                        <label>
                            <span data-i18n="estate-class">Estate Class</span>
                            <select asp-for="AdvanceForm.EstateClass" class="form-select">
                                <option value="@Eu5ModPlanner.Models.EstateClass.Upper" data-i18n-option="estate-class-upper">Upper Class</option>
                                <option value="@Eu5ModPlanner.Models.EstateClass.Lower" data-i18n-option="estate-class-lower">Lower Class</option>
                            </select>
                        </label>
                        <label class="checkbox-row">
                            <input asp-for="AdvanceForm.CanPromote" class="form-check-input" type="checkbox" data-can-promote-toggle />
                            <span data-i18n="can-promote">Can Promote?</span>
                        </label>
                        <label data-promotion-speed-row>
