@model Eu5ModPlanner.Models.PlannerIndexViewModel
@{
    ViewData["Title"] = "Planner";
    var availableCustomEstates = Model.SelectedCountryContent
        .Where(entry => entry.Type == Eu5ModPlanner.Models.ContentType.CustomEstate)
        .Select(entry => entry.Name)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(name => name)
        .ToList();
    var availableEventEntries = Model.SelectedCountryContent
        .Where(entry => entry.Type == Eu5ModPlanner.Models.ContentType.Event)
        .OrderBy(entry => entry.Name)
        .ToList();
    var availableCultureGroups = Model.AvailableCultureGroups
        .OrderBy(entry => entry.Name)
        .ToList();
}

<div class="auth-banner">
    <div class="auth-banner-copy">
        @if (Model.HasWriteAccess)
        {
            <strong data-i18n="auth-write-title">Write access enabled</strong>
            @if (Model.IsAuthenticatedUser)
            {
                <span>@Model.CurrentUserDisplayName (@Model.CurrentUserRoleName) - <span data-i18n="auth-write-copy">You can add, edit, and delete content.</span></span>
            }
            else
            {
                <span data-i18n="auth-write-copy">You can add, edit, and delete content.</span>
            }
        }
        else if (Model.HasAnyAccounts)
        {
            <strong data-i18n="auth-readonly-title">Read-only mode</strong>
            <span data-i18n="auth-readonly-copy">Browsing is public. Sign in to edit the database.</span>
        }
        else
        {
            <strong data-i18n="auth-unconfigured-title">Read-only mode</strong>
            <span data-i18n="auth-unconfigured-copy">No active user accounts are configured yet, so editing is disabled.</span>
        }
    </div>
    <div class="content-chip-row">
        @if (Model.CanManageWriteAccess && Model.HasWriteAccess)
        {
            <form asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="library" value="@Model.ActiveLibrary" />
                <input type="hidden" name="countryId" value="@Model.SelectedCountry?.Id" />
                <input type="hidden" name="cultureId" value="@Model.SelectedCulture?.Id" />
                <input type="hidden" name="cultureGroupId" value="@Model.SelectedCultureGroup?.Id" />
                <input type="hidden" name="contentId" value="@Model.SelectedContent?.Id" />
                <button type="submit" class="material-button ghost-button">
                    <span data-i18n="auth-logout">Sign out</span>
                </button>
            </form>
        }
        else if (Model.CanManageWriteAccess)
        {
            <button type="button" class="material-button primary-button" data-bs-toggle="modal" data-bs-target="#loginModal">
                <span data-i18n="auth-login">Sign in</span>
            </button>
        }
        @if (Model.CanManageUsers)
        {
            <button type="button" class="material-button ghost-button" data-bs-toggle="modal" data-bs-target="#usersModal">
                <span data-i18n="auth-manage-users">Manage users</span>
            </button>
        }
    </div>
</div>

<div class="modal fade" id="buffLibraryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content planner-modal">
            <div class="modal-header">
                <h2 class="modal-title fs-5" data-i18n="buff-library-title">Buff library</h2>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="buff-library-panel">
                    <div class="effects-editor-header">
                        <h3 data-i18n="available-buffs">Available buffs</h3>
                        <button type="button" class="material-button primary-button small-button" data-buff-new-button>
                            <span data-i18n="new-buff">New buff</span>
                        </button>
                    </div>
                    <div class="buff-library-list" data-buff-list></div>
                    <p class="helper-copy" data-buff-empty-state data-i18n="buff-library-empty">No buffs yet. Create the first one here.</p>
                </div>
            </div>
            <div class="modal-footer buff-library-footer">
                <span class="helper-copy" data-buff-library-status></span>
                <button type="button" class="material-button ghost-button" data-bs-dismiss="modal" data-i18n="cancel">Cancel</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="buffEditorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content planner-modal">
            <div class="modal-header">
                <h2 class="modal-title fs-5" data-buff-form-title data-i18n="new-buff">New buff</h2>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="buffForm" class="effects-editor">
                @Html.AntiForgeryToken()
                <input asp-for="BuffForm.Id" type="hidden" data-buff-form-id />
                <div class="modal-body modal-form">
                    <label>
                        <span data-i18n="buff-name">Buff name</span>
                        <input asp-for="BuffForm.Name" class="form-control" data-buff-name-input data-i18n-placeholder="buff-name-placeholder" />
                    </label>
                    <div class="effects-editor">
                        <div class="effects-editor-header">
                            <h3 data-i18n="effects-title">Effects</h3>
                            <button type="button" class="material-button ghost-button" data-add-buff-effect>
                                <span data-i18n="add-effect">Add effect</span>
                            </button>
                        </div>
                        <div data-buff-effects-container></div>
                    </div>
                </div>
                <div class="modal-footer buff-editor-footer">
                    <span class="helper-copy" data-buff-status></span>
                    <div class="content-chip-row">
                        <button type="button" class="material-button danger-button" data-buff-delete-button hidden>
                            <span data-i18n="delete-buff">Delete buff</span>
                        </button>
                        <button type="button" class="material-button ghost-button" data-bs-dismiss="modal" data-i18n="cancel">Cancel</button>
                        <button type="button" class="material-button primary-button" data-buff-save-button>
                            <span data-buff-save-label data-i18n="save-buff">Save buff</span>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<section class="planner-shell">
    <aside class="planner-pane pane-countries">
        <div class="pane-header pane-header-stacked">
            <div>
                <p class="pane-kicker" data-i18n="library-kicker">Library</p>
                <h1>
                    @if (Model.ActiveLibrary == "CultureGroups")
                    {
                        <span data-i18n="culture-groups-title">Culture Groups</span>
                    }
                    else if (Model.ActiveLibrary == "Cultures")
                    {
                        <span data-i18n="cultures-title">Cultures</span>
                    }
                    else
                    {
                        <span data-i18n="countries-title">Tags</span>
                    }
                </h1>
            </div>
            <div class="segmented-control library-switcher">
                <a class="segment @(Model.ActiveLibrary == "Countries" ? "is-active" : null)" asp-action="Index" asp-route-library="Countries" data-i18n="countries-title">Tags</a>
                <a class="segment @(Model.ActiveLibrary == "CultureGroups" ? "is-active" : null)" asp-action="Index" asp-route-library="CultureGroups" data-i18n="culture-groups-title">Culture Groups</a>
                <a class="segment @(Model.ActiveLibrary == "Cultures" ? "is-active" : null)" asp-action="Index" asp-route-library="Cultures" data-i18n="cultures-title">Cultures</a>
            </div>
        </div>

        @if (Model.ActiveLibrary == "Countries")
        {
            <div class="pane-header-actions">
                @if (Model.HasWriteAccess)
                {
                    <button type="button" class="material-button primary-button" data-bs-toggle="modal" data-bs-target="#addCountryModal">
                        <span data-i18n="add-tag">Add tag</span>
                    </button>
                }
                @if (Model.ArchivedCountries.Count > 0)
                {
                    <button type="button" class="material-button ghost-button small-button" data-bs-toggle="modal" data-bs-target="#archivedCountriesModal">
                        <span data-i18n="archived-tags-button">Archived tags</span>
                    </button>
                }
            </div>

            @if (Model.Countries.Count == 0)
            {
                <div class="empty-panel">
                    <p data-i18n="countries-empty">No countries yet. Add your first tag to begin.</p>
                </div>
            }
            else if (Model.ActiveCountries.Count > 0)
            {
                <div class="country-section">
                    <div class="country-stack">
                        @foreach (var country in Model.ActiveCountries)
                        {
                            var isSelected = Model.SelectedCountry?.Id == country.Id;
                            <a class="country-tile @(isSelected ? "is-selected" : null)"
                               asp-action="Index"
                               asp-route-library="Countries"
                               asp-route-countryId="@country.Id">
                                <div class="country-tag">@country.Tag</div>
                                <div class="country-copy">
                                    <strong>@country.Name</strong>
                                    <span>@country.ContentEntryIds.Count <span data-i18n="content-label-inline">entries</span></span>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }

            @if (Model.SelectedCountry is not null)
            {
                <div class="selected-country-card">
                    <div class="detail-topline">
                        <div class="country-copy">
                            <span class="pane-kicker" data-i18n="selected-country-kicker">Selected tag</span>
                            <strong>@Model.SelectedCountry.Name</strong>
                            <span>@Model.SelectedCountry.Tag</span>
                        </div>
                        <div class="content-chip-row">
                            <span class="type-chip @(Model.SelectedCountry.IsArchived ? "archived-chip" : null)"
                                  data-i18n="@(Model.SelectedCountry.IsArchived ? "country-status-archived" : "country-status-active")">
                                @(Model.SelectedCountry.IsArchived ? "Archived" : "Active")
                            </span>
                        </div>
                    </div>
                    @if (Model.HasWriteAccess)
                    {
                        <div class="content-chip-row">
                            <button type="button" class="material-button ghost-button" data-bs-toggle="modal" data-bs-target="#editCountryModal">
                                <span data-i18n="edit-country">Edit tag</span>
                            </button>
                            @if (Model.SelectedCountry.IsArchived)
                            {
                                <form asp-action="RestoreCountry" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="countryId" value="@Model.SelectedCountry.Id" />
                                    <button type="submit" class="material-button primary-button">
                                        <span data-i18n="restore-country">Restore tag</span>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="ArchiveCountry" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="countryId" value="@Model.SelectedCountry.Id" />
                                    <button type="submit" class="material-button danger-button">
                                        <span data-i18n="archive-country">Archive tag</span>
                                    </button>
                                </form>
                            }
                        </div>
                    }
                </div>
            }
        }
        else if (Model.ActiveLibrary == "CultureGroups")
        {
            <div class="pane-header-actions">
                @if (Model.HasWriteAccess)
                {
                    <button type="button" class="material-button primary-button" data-bs-toggle="modal" data-bs-target="#addContentModal" data-create-type="CultureGroup">
                        <span data-i18n="add-culture-group">Add culture group</span>
                    </button>
                }
                @if (Model.ArchivedCultureGroups.Count > 0)
                {
                    <button type="button" class="material-button ghost-button small-button" data-bs-toggle="modal" data-bs-target="#archivedCultureGroupsModal">
                        <span data-i18n="archived-culture-groups-button">Archived culture groups</span>
                    </button>
                }
            </div>

            @if (Model.AvailableCultureGroups.Count == 0)
            {
                <div class="empty-panel">
                    <p data-i18n="culture-groups-empty">No culture groups exist yet.</p>
                </div>
            }
            else
            {
                <div class="country-stack">
                    @foreach (var group in Model.AvailableCultureGroups)
                    {
                        var isSelectedGroup = Model.SelectedCultureGroup?.Id == group.Id;
                        <a class="country-tile @(isSelectedGroup ? "is-selected" : null)"
                           asp-action="Index"
                           asp-route-library="CultureGroups"
                           asp-route-cultureGroupId="@group.Id">
                            <div class="country-tag">CG</div>
                            <div class="country-copy">
                                <strong>@group.Name</strong>
                                <span>@group.CultureGroupContentEntryIds.Count <span data-i18n="content-label-inline">entries</span></span>
                            </div>
                        </a>
                    }
                </div>
            }

            @if (Model.SelectedCultureGroup is not null)
            {
                <div class="selected-country-card">
                    <div class="detail-topline">
                        <div class="country-copy">
                            <span class="pane-kicker" data-i18n="selected-culture-group-kicker">Selected culture group</span>
                            <strong>@Model.SelectedCultureGroup.Name</strong>
                            <span>@Model.SelectedCultureGroup.CultureGroupContentEntryIds.Count <span data-i18n="content-label-inline">entries</span></span>
                        </div>
                        <div class="content-chip-row">
                            <span class="type-chip @(Model.SelectedCultureGroup.IsArchived ? "archived-chip" : null)"
                                  data-i18n="@(Model.SelectedCultureGroup.IsArchived ? "country-status-archived" : "country-status-active")">
                                @(Model.SelectedCultureGroup.IsArchived ? "Archived" : "Active")
                            </span>
                        </div>
                    </div>
                    @if (Model.HasWriteAccess)
                    {
                        <div class="content-chip-row">
                            <button type="button" class="material-button ghost-button" data-edit-content-button data-bs-toggle="modal" data-bs-target="#addContentModal">
                                <span data-i18n="edit-culture-group">Edit culture group</span>
                            </button>
                            @if (Model.SelectedCultureGroup.IsArchived)
                            {
                                <form asp-action="RestoreLibraryEntry" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="library" value="@Model.ActiveLibrary" />
                                    <input type="hidden" name="contentId" value="@Model.SelectedCultureGroup.Id" />
                                    <button type="submit" class="material-button primary-button">
                                        <span data-i18n="restore-culture-group">Restore culture group</span>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="ArchiveLibraryEntry" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="library" value="@Model.ActiveLibrary" />
                                    <input type="hidden" name="contentId" value="@Model.SelectedCultureGroup.Id" />
                                    <button type="submit" class="material-button danger-button">
                                        <span data-i18n="archive-culture-group">Archive culture group</span>
                                    </button>
                                </form>
                            }
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="pane-header-actions">
                @if (Model.HasWriteAccess)
                {
                    <button type="button" class="material-button primary-button" data-bs-toggle="modal" data-bs-target="#addContentModal" data-create-type="Culture">
                        <span data-i18n="add-culture">Add culture</span>
                    </button>
                }
                @if (Model.ArchivedCultures.Count > 0)
                {
                    <button type="button" class="material-button ghost-button small-button" data-bs-toggle="modal" data-bs-target="#archivedCulturesModal">
                        <span data-i18n="archived-cultures-button">Archived cultures</span>
                    </button>
                }
            </div>

            @if (Model.AvailableCultures.Count == 0)
            {
                <div class="empty-panel">
                    <p data-i18n="cultures-empty">No cultures exist yet.</p>
                </div>
            }
            else
            {
                <div class="country-stack">
                    @foreach (var culture in Model.AvailableCultures)
                    {
                        var isSelectedCulture = Model.SelectedCulture?.Id == culture.Id;
                        <a class="country-tile @(isSelectedCulture ? "is-selected" : null)"
                           asp-action="Index"
                           asp-route-library="Cultures"
                           asp-route-cultureId="@culture.Id">
                            <div class="country-tag">CU</div>
                            <div class="country-copy">
                                <strong>@culture.Name</strong>
                                <span>@culture.CultureGroupNames.Count <span data-i18n="culture-group-memberships">groups</span></span>
                            </div>
                        </a>
                    }
                </div>
            }

            @if (Model.SelectedCulture is not null)
            {
                <div class="selected-country-card">
                    <div class="detail-topline">
                        <div class="country-copy">
                            <span class="pane-kicker" data-i18n="selected-culture-kicker">Selected culture</span>
                            <strong>@Model.SelectedCulture.Name</strong>
                            <span>@Model.SelectedCulture.CultureGroupNames.Count <span data-i18n="culture-group-memberships">groups</span></span>
                        </div>
                        <div class="content-chip-row">
                            <span class="type-chip @(Model.SelectedCulture.IsArchived ? "archived-chip" : null)"
                                  data-i18n="@(Model.SelectedCulture.IsArchived ? "country-status-archived" : "country-status-active")">
                                @(Model.SelectedCulture.IsArchived ? "Archived" : "Active")
                            </span>
                        </div>
                    </div>
                    <div class="effect-detail-list">
                        @foreach (var groupName in Model.SelectedCulture.CultureGroupNames)
                        {
                            <div class="effect-detail-item">@groupName</div>
                        }
                    </div>
                    @if (Model.HasWriteAccess)
                    {
                        <div class="content-chip-row">
                            <button type="button" class="material-button ghost-button" data-edit-content-button data-bs-toggle="modal" data-bs-target="#addContentModal">
                                <span data-i18n="edit-culture">Edit culture</span>
                            </button>
                            @if (Model.SelectedCulture.IsArchived)
                            {
                                <form asp-action="RestoreLibraryEntry" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="library" value="@Model.ActiveLibrary" />
                                    <input type="hidden" name="contentId" value="@Model.SelectedCulture.Id" />
                                    <button type="submit" class="material-button primary-button">
                                        <span data-i18n="restore-culture">Restore culture</span>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="ArchiveLibraryEntry" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="library" value="@Model.ActiveLibrary" />
                                    <input type="hidden" name="contentId" value="@Model.SelectedCulture.Id" />
                                    <button type="submit" class="material-button danger-button">
                                        <span data-i18n="archive-culture">Archive culture</span>
                                    </button>
                                </form>
                            }
                        </div>
                    }
                </div>
            }
        }
    </aside>

    <section class="planner-pane pane-content">
        <div class="pane-header">
            <div>
                <p class="pane-kicker" data-i18n="@(Model.ActiveLibrary == "CultureGroups" ? "culture-group-content-kicker" : Model.ActiveLibrary == "Cultures" ? "cultures-title" : "content-kicker")">Country content</p>
                <h2>
                    @if (Model.ActiveLibrary == "Countries")
                    {
                        @if (Model.SelectedCountry is null)
                        {
                            <span data-i18n="content-title-empty">Pick a country</span>
                        }
                        else
                        {
                            <span>@Model.SelectedCountry.Tag</span>
                        }
                    }
                    else if (Model.ActiveLibrary == "CultureGroups")
                    {
                        @if (Model.SelectedCultureGroup is null)
                        {
                            <span data-i18n="culture-groups-title">Culture Groups</span>
                        }
                        else
                        {
                            <span>@Model.SelectedCultureGroup.Name</span>
                        }
                    }
                    else
                    {
                        @if (Model.SelectedCulture is null)
                        {
                            <span data-i18n="cultures-title">Cultures</span>
                        }
                        else
                        {
                            <span>@Model.SelectedCulture.Name</span>
                        }
                    }
                </h2>
            </div>
            @if (Model.ActiveLibrary != "Cultures")
            {
                <button type="button"
                        class="material-button primary-button"
                        data-bs-toggle="modal"
                        data-bs-target="#addContentModal"
                        data-add-content-button
                        disabled="@(((Model.ActiveLibrary == "Countries" && Model.SelectedCountry is null) || (Model.ActiveLibrary == "CultureGroups" && Model.SelectedCultureGroup is null)) || !Model.HasWriteAccess)">
                    <span data-i18n="add-content">Add content</span>
                </button>
            }
        </div>

        @if (Model.ActiveLibrary == "Countries" && Model.SelectedCountry is null)
        {
            <div class="empty-panel">
                <p data-i18n="select-country-empty">Create or select a country to manage its unique content.</p>
            </div>
        }
        else if (Model.ActiveLibrary == "CultureGroups" && Model.SelectedCultureGroup is null)
        {
            <div class="empty-panel">
                <p data-i18n="culture-group-select-empty">Select a culture group to manage its shared content.</p>
            </div>
        }
        else if (Model.ActiveLibrary == "Cultures")
        {
            <div class="empty-panel">
                <p data-i18n="cultures-detail-empty">Cultures are shared reference entities. Select one to inspect its memberships.</p>
            </div>
        }
        else if (Model.SelectedCountryContent.Count == 0)
        {
            <div class="empty-panel">
                <p data-i18n="@(Model.ActiveLibrary == "CultureGroups" ? "culture-group-content-empty" : "content-empty")">This country has no unique content yet.</p>
            </div>
        }
        else
        {
            <div class="content-stack">
                @foreach (var item in Model.SelectedCountryContent)
                {
                    var isSelected = Model.SelectedContent?.Id == item.Id;
                    <a class="content-tile @(isSelected ? "is-selected" : null)"
                       asp-action="Index"
                       asp-route-library="@Model.ActiveLibrary"
                       asp-route-countryId="@Model.SelectedCountry?.Id"
                       asp-route-cultureGroupId="@Model.SelectedCultureGroup?.Id"
                       asp-route-contentId="@item.Id">
                        <div class="content-meta">
                            <div class="content-chip-row">
                                <span class="type-chip" data-i18n="@item.TypeTranslationKey">@(item.Type switch { Eu5ModPlanner.Models.ContentType.Reform => "Reform", Eu5ModPlanner.Models.ContentType.DefaultEstateRename => "Default Estate Rename", Eu5ModPlanner.Models.ContentType.CustomEstate => "Custom Estate", Eu5ModPlanner.Models.ContentType.Privilege => "Privilege", Eu5ModPlanner.Models.ContentType.Law => "Law", Eu5ModPlanner.Models.ContentType.Value => "Value", Eu5ModPlanner.Models.ContentType.Building => "Building", Eu5ModPlanner.Models.ContentType.Event => "Event", Eu5ModPlanner.Models.ContentType.Situation => "Situation", Eu5ModPlanner.Models.ContentType.Culture => "Culture", Eu5ModPlanner.Models.ContentType.CultureGroup => "Culture Group", _ => "Advance" })</span>
                                @if (item.Type == Eu5ModPlanner.Models.ContentType.Reform && item.IsMajorReform)
                                {
                                    <span class="type-chip major-chip" data-i18n="major-reform">Major Reform</span>
                                }
                            </div>
                            <strong>@item.Name</strong>
                        </div>
                    </a>
                }
            </div>
        }
    </section>

    <aside class="planner-pane pane-detail">
        <div class="pane-header pane-header-stacked">
            <div>
                <p class="pane-kicker" data-i18n="detail-kicker">Details</p>
                <h2 data-i18n="detail-title">Selected content</h2>
            </div>
            @if (Model.SelectedContent is not null && Model.ActiveLibrary != "Cultures")
            {
                <div class="pane-header-actions">
                    @if (Model.HasWriteAccess && Model.SelectedContent.Type is not Eu5ModPlanner.Models.ContentType.CultureGroup)
                    {
                        <button type="button" class="material-button ghost-button" data-edit-content-button data-bs-toggle="modal" data-bs-target="#addContentModal">
                            <span data-i18n="edit-content">Edit</span>
                        </button>
                        <form asp-action="DeleteContent" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="library" value="@Model.ActiveLibrary" />
                            <input type="hidden" name="countryId" value="@Model.SelectedCountry?.Id" />
                            <input type="hidden" name="cultureId" value="@Model.SelectedCulture?.Id" />
                            <input type="hidden" name="cultureGroupId" value="@Model.SelectedCultureGroup?.Id" />
                            <input type="hidden" name="contentId" value="@Model.SelectedContent.Id" />
                            <button type="submit" class="material-button danger-button">
                                <span data-i18n="delete-content">Delete</span>
                            </button>
                        </form>
                    }
                </div>
            }
        </div>

        @if (Model.SelectedContent is null && Model.SelectedCultureGroup is null)
        {
            <div class="empty-panel">
                <p data-i18n="detail-empty">Select a content piece to inspect its effect.</p>
            </div>
        }
        else if (Model.SelectedContent is null && Model.SelectedCultureGroup is not null)
        {
            <div class="detail-card">
                <div class="detail-topline">
                    <div class="content-chip-row">
                        <span class="type-chip" data-i18n="type-culture-group">Culture Group</span>
                    </div>
                    <h3>@Model.SelectedCultureGroup.Name</h3>
                </div>
                <div class="effect-detail-list">
                    @foreach (var effect in Model.SelectedCultureGroup.DisplayLines)
                    {
                        <div class="effect-detail-item">@effect</div>
                    }
                </div>
            </div>
        }
        else
        {
            var selectedContent = Model.SelectedContent!;
            <div class="detail-card">
                <div class="detail-topline">
                    <div class="content-chip-row">
                        <span class="type-chip" data-i18n="@selectedContent.TypeTranslationKey">@(selectedContent.Type switch { Eu5ModPlanner.Models.ContentType.Reform => "Reform", Eu5ModPlanner.Models.ContentType.DefaultEstateRename => "Default Estate Rename", Eu5ModPlanner.Models.ContentType.CustomEstate => "Custom Estate", Eu5ModPlanner.Models.ContentType.Privilege => "Privilege", Eu5ModPlanner.Models.ContentType.Law => "Law", Eu5ModPlanner.Models.ContentType.Value => "Value", Eu5ModPlanner.Models.ContentType.Building => "Building", Eu5ModPlanner.Models.ContentType.Event => "Event", Eu5ModPlanner.Models.ContentType.Situation => "Situation", Eu5ModPlanner.Models.ContentType.Culture => "Culture", Eu5ModPlanner.Models.ContentType.CultureGroup => "Culture Group", _ => "Advance" })</span>
                        @if (selectedContent.Type is Eu5ModPlanner.Models.ContentType.Culture or Eu5ModPlanner.Models.ContentType.CultureGroup)
                        {
                            <span class="type-chip @(selectedContent.IsArchived ? "archived-chip" : null)"
                                  data-i18n="@(selectedContent.IsArchived ? "country-status-archived" : "country-status-active")">
                                @(selectedContent.IsArchived ? "Archived" : "Active")
                            </span>
                        }
                        @if (selectedContent.Type == Eu5ModPlanner.Models.ContentType.Reform && selectedContent.IsMajorReform)
                        {
                            <span class="type-chip major-chip" data-i18n="major-reform">Major Reform</span>
                        }
                    </div>
                    <h3>@selectedContent.Name</h3>
                </div>
                <div class="effect-detail-list">
                    @foreach (var effect in selectedContent.DisplayLines)
                    {
                        <div class="effect-detail-item">@effect</div>
                    }
                </div>
            </div>
        }
    </aside>
</section>

