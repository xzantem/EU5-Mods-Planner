<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Eu5ModPlanner</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Eu5ModPlanner.styles.css" asp-append-version="true" />
</head>
<body class="theme-dark" data-lang="en">
    <header class="app-bar">
        <div class="container-xl app-bar-inner">
            <div class="brand-block">
                <span class="brand-mark">E5</span>
                <div>
                    <strong>EU5 Mod Planner</strong>
                    <small data-i18n="shell-subtitle">Country content editor</small>
                </div>
            </div>
            <div class="shell-controls">
                <div class="segmented-control" role="group" aria-label="Language switch">
                    <button type="button" class="segment is-active" data-language="en">EN</button>
                    <button type="button" class="segment" data-language="pl">PL</button>
                </div>
                <button type="button" class="material-button ghost-button theme-toggle" data-theme-toggle>
                    <span data-i18n="toggle-theme">Dark mode</span>
                </button>
            </div>
        </div>
    </header>

    <div class="container-xl app-body">
        @if (TempData["Message"] is string message)
        {
            <div class="planner-toast" role="status">@message</div>
        }
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
